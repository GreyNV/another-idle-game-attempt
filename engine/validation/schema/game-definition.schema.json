{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://another-idle-game-attempt.dev/schemas/game-definition.schema.json",
  "title": "Game Definition (engine parser-aligned)",
  "type": "object",
  "required": [
    "meta",
    "systems",
    "state",
    "layers"
  ],
  "additionalProperties": true,
  "$comment": "Schema sync contract: parseGameDefinition in engine/validation/parser/parseGameDefinition.js is source-of-truth. Keep this schema aligned with validateGameDefinitionSchema + unlockCondition parser. Softcap mode policy for schema major 1 is enum ['power']; future schema majors must intentionally version this section instead of widening silently.",
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "schemaVersion",
        "gameId"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "pattern": "^1\\.(0|1|2)(?:\\.\\d+)?$",
          "$comment": "Matches engine/validation/schema/schemaVersionPolicy.js defaults (major 1, minor 0-2)."
        },
        "gameId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "systems": {
      "type": "object"
    },
    "state": {
      "type": "object"
    },
    "layers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/layer"
      },
      "uniqueItemProperties": [
        "id"
      ]
    },
    "modifiers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modifier"
      },
      "uniqueItemProperties": [
        "id"
      ]
    }
  },
  "$defs": {
    "layer": {
      "type": "object",
      "required": [
        "id",
        "type",
        "sublayers"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "progressLayer",
            "inventoryLayer",
            "statisticsLayer"
          ]
        },
        "unlock": {
          "$ref": "#/$defs/unlockCondition"
        },
        "sublayers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sublayer"
          },
          "uniqueItemProperties": [
            "id"
          ]
        },
        "softcaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/softcap"
          },
          "uniqueItemProperties": [
            "id"
          ]
        },
        "modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modifier"
          },
          "uniqueItemProperties": [
            "id"
          ]
        }
      },
      "additionalProperties": true
    },
    "sublayer": {
      "type": "object",
      "required": [
        "id",
        "type",
        "sections"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "progress",
            "buyable",
            "upgrade"
          ]
        },
        "unlock": {
          "$ref": "#/$defs/unlockCondition"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          },
          "uniqueItemProperties": [
            "id"
          ]
        }
      },
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "required": [
        "id",
        "elements"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "unlock": {
          "$ref": "#/$defs/unlockCondition"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/element"
          },
          "uniqueItemProperties": [
            "id"
          ]
        }
      },
      "additionalProperties": true
    },
    "element": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "progressBar",
            "buyable",
            "upgrade",
            "routine"
          ]
        },
        "unlock": {
          "$ref": "#/$defs/unlockCondition"
        },
        "modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modifier"
          },
          "uniqueItemProperties": [
            "id"
          ]
        }
      },
      "additionalProperties": true
    },
    "softcap": {
      "type": "object",
      "required": [
        "id",
        "mode"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "targetRef": {
          "type": "string",
          "minLength": 1
        },
        "targetKey": {
          "type": "string",
          "minLength": 1
        },
        "threshold": {
          "type": "number"
        },
        "power": {
          "type": "number"
        },
        "multiplier": {
          "type": "number"
        },
        "priority": {
          "type": "number"
        },
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "power"
          ],
          "$comment": "Schema major 1 softcap mode enum. For future majors, introduce explicit versioned enum branches rather than widening this enum in-place."
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "softcapAt": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "unlockCondition": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "always"
          ],
          "properties": {
            "always": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "resourceGte"
          ],
          "properties": {
            "resourceGte": {
              "type": "object",
              "required": [
                "path",
                "value"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "value": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "compare"
          ],
          "properties": {
            "compare": {
              "type": "object",
              "required": [
                "path",
                "op",
                "value"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "op": {
                  "enum": [
                    "gt",
                    "gte",
                    "lt",
                    "lte",
                    "eq",
                    "neq"
                  ]
                },
                "value": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "flag"
          ],
          "properties": {
            "flag": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/unlockCondition"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/unlockCondition"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/unlockCondition"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "modifier": {
      "type": "object",
      "required": [
        "id",
        "targetRef",
        "key",
        "op",
        "value"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "targetRef": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "number"
        },
        "stacking": {
          "type": "string",
          "enum": [
            "stack",
            "replace"
          ]
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "enabled": {
          "type": "boolean"
        },
        "priority": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "schemaVersion": {
                "pattern": "^1\\.(0|1)(?:\\.|$)"
              }
            },
            "required": [
              "schemaVersion"
            ]
          }
        },
        "required": [
          "meta"
        ]
      },
      "then": {
        "not": {
          "properties": {
            "layers": {
              "type": "array",
              "contains": {
                "type": "object",
                "properties": {
                  "sublayers": {
                    "type": "array",
                    "contains": {
                      "type": "object",
                      "properties": {
                        "sections": {
                          "type": "array",
                          "contains": {
                            "type": "object",
                            "properties": {
                              "elements": {
                                "type": "array",
                                "contains": {
                                  "type": "object",
                                  "properties": {
                                    "type": {
                                      "const": "routine"
                                    }
                                  },
                                  "required": [
                                    "type"
                                  ]
                                }
                              }
                            },
                            "required": [
                              "elements"
                            ]
                          }
                        }
                      },
                      "required": [
                        "sections"
                      ]
                    }
                  }
                },
                "required": [
                  "sublayers"
                ]
              }
            }
          },
          "required": [
            "layers"
          ]
        }
      }
    }
  ]
}

